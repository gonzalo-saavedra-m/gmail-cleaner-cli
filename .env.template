# OAuth client credentials from Google Cloud Console.
GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-oauth-client-secret

# Startup query. You can change the active query from the menu without editing this file.
DEFAULT_QUERY=is:unread older_than:6m

GOOGLE_REFRESH_TOKEN_FILE=.secrets/google_refresh_token.enc

# The app auto-generates this when you connect a Gmail account from the menu.
TOKEN_ENCRYPTION_KEY=your-generated-encryption-key

# The script starts a one-shot local callback server here during OAuth setup.
GOOGLE_REDIRECT_URI=http://127.0.0.1:8765/callback
